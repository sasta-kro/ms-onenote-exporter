# Copy this file to .env and fill in your own values.
# .env is ignored by git because it can contain private app/account details.

# REQUIRED: Microsoft Entra Application/client ID.
#
# This value is prefilled with the shared app registration for the organization.
# People in the same organization can reuse this client ID; a new app
# registration is not needed unless the shared app stops working or a different
# organization needs its own app.
#
# How to get it:
# 1. Open Microsoft Entra admin center:
#    https://entra.microsoft.com/
# 2. In the left sidebar, go to:
#    Identity -> Applications -> App registrations
# 3. Open the app registration you created for this exporter.
#    If you have not created one yet, use New registration first.
#    Microsoft guide:
#    https://learn.microsoft.com/en-us/entra/identity-platform/quickstart-register-app
# 4. On the app's Overview page, copy:
#    Application (client) ID
# 5. Paste that GUID after ONENOTE_CLIENT_ID= below.
#
# This is not your student ID, email address, tenant ID, or SharePoint ID.
# Do not paste the "Directory (tenant) ID" here.
ONENOTE_CLIENT_ID=43e0fa96-05a2-4479-ae9c-7d88e22cf6d7

# USUALLY KEEP THIS DEFAULT FOR UNI/ORG NOTEBOOKS.
#
# "organizations" means Microsoft work/school accounts only.
# That is the normal choice for Teams/Class Notebook exports.
#
# Other valid values if you intentionally need them:
# - Directory (tenant) ID from the same app Overview page.
# - Tenant domain, for example yourschool.edu.
# - common, for both personal Microsoft accounts and work/school accounts.
# - consumers, for personal Microsoft accounts only.
ONENOTE_TENANT_ID=organizations

# OPTIONAL BUT USEFUL: resolved Graph site ID for one Teams/Class Notebook site.
#
# How to get it:
# 1. Run: python main.py --site-url "PASTE_TEAMS_OR_ONENOTE_BROWSER_LINK"
# 2. Open the two helper links the app prints.
# 3. Paste each XML page back into the terminal.
# 4. Copy the "Resolved site ID" value printed by the app.
#
# Shape:
# yourtenant.sharepoint.com,siteCollectionGuid,webGuid
ONENOTE_SITE_ID=

# OPTIONAL: local output directory.
#
# Relative paths are created inside this project folder.
# Absolute paths also work, for example /Users/you/OneNoteExport.
ONENOTE_OUT=onenote_export

# OPTIONAL: extra formats to create next to HTML.
#
# Leave blank for HTML only.
# Use md, txt, rtf, html, or comma-separated values like md,txt.
# HTML is always exported, so "html" is accepted but does not add another file.
# Markdown/TXT/RTF conversion requires pandoc: brew install pandoc
ONENOTE_FORMATS=

# OPTIONAL: only export notebooks whose name contains this text.
#
# Example:
# ONENOTE_NOTEBOOK=2026-1 BAD 542 Notebook
ONENOTE_NOTEBOOK=

# OPTIONAL: local MSAL token cache path.
#
# This stores Microsoft login tokens so you do not need to sign in every run.
# Keep this file private. Delete it if you want to force a fresh login.
ONENOTE_TOKEN_CACHE=.msal_token_cache.json
