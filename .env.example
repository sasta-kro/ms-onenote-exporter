# Copy this file to .env and fill in your own values.
# .env is ignored by git because it can contain private app/account details.

# Required: Microsoft Entra Application/client ID.
ONENOTE_CLIENT_ID=

# Good default for work/school accounts. You can also use a tenant ID or domain.
ONENOTE_TENANT_ID=organizations

# Where to read OneNote notebooks from.
# Common values: /me, /groups/GROUP_ID, /sites/SITE_ID
ONENOTE_LOCATION=/me

# Optional: Teams/SharePoint URL for a class notebook site. Overrides ONENOTE_LOCATION.
# Example: https://yourtenant.sharepoint.com/teams/2026-GDD-542/Shared%20Documents
ONENOTE_SITE_URL=

# Local output directory.
ONENOTE_OUT=onenote_export

# Optional: only export notebooks whose name contains this text.
ONENOTE_NOTEBOOK=

# Optional: leave blank for HTML only. Use md, txt, rtf, or comma-separated values.
# Markdown/TXT/RTF conversion requires pandoc.
ONENOTE_FORMATS=

# Local MSAL token cache path. Keep this file private.
ONENOTE_TOKEN_CACHE=.msal_token_cache.json
