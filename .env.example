# Copy this file to .env.
# For Assumption University students, the preset auth values below are enough.
# No need to change anything in this file.

# Shared Microsoft Entra app registration for this exporter app.
# This is the same app ID for all Assumption University users.
# Students with an @au.edu Microsoft account do not need to change this.
ONENOTE_CLIENT_ID=43e0fa96-05a2-4479-ae9c-7d88e22cf6d7

# Assumption University Microsoft tenant ID.
# This is the same tenant GUID for everyone in the AU Microsoft organization.
# Students with an @au.edu Microsoft account do not need to change this.
ONENOTE_TENANT_ID=c1f3dc23-b7f8-48d3-9b5d-2b12f158f01f

# Optional: resolved Graph site ID for one Teams/Class Notebook site.
# The app prints this after running:
# python main.py --site-url "PASTE_TEAMS_OR_ONENOTE_BROWSER_LINK"
# Shape: school.sharepoint.com,siteCollectionGuid,webGuid
ONENOTE_SITE_ID=

# Optional: local output directory.
ONENOTE_OUT=onenote_export

# Optional: extra formats next to HTML.
# Leave blank for HTML only. Values: md, txt, rtf, html, or md,txt.
# Markdown/TXT/RTF conversion requires pandoc: brew install pandoc
ONENOTE_FORMATS=

# Optional: only export notebooks whose name contains this text.
# Example: ONENOTE_NOTEBOOK=2026-1 BAD 542 Notebook
ONENOTE_NOTEBOOK=

# Optional: local MSAL token cache path. Keep this file private.
ONENOTE_TOKEN_CACHE=.msal_token_cache.json
